# TripPlanner Environment Configuration
# Copy this file to .env.local and fill in your API keys

# Anthropic API Key (required for AI features)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API Key (required for RAG/embeddings features)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI Embedding Configuration (optional)
# Model for generating embeddings - options: text-embedding-3-small, text-embedding-3-large
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Embedding dimensions (1536 for text-embedding-3-small, 3072 for text-embedding-3-large)
OPENAI_EMBEDDING_DIMENSIONS=1536

# Optional: Custom API endpoint
# API_URL=http://localhost:3011

# Optional: CORS origin for API
# CORS_ORIGIN=http://localhost:3010
