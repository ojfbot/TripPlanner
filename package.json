{
  "name": "tripplanner",
  "version": "0.1.0",
  "description": "AI-powered trip planning and itinerary management system",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24.11.1",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @tripplanner/browser-app dev",
    "dev:api": "pnpm --filter @tripplanner/api dev",
    "dev:all": "concurrently \"pnpm dev:api\" \"pnpm dev\"",
    "build": "pnpm --recursive --if-present build",
    "prebuild": "pnpm type-check",
    "preview": "pnpm --filter @tripplanner/browser-app preview",
    "type-check": "pnpm --recursive --if-present type-check",
    "clean": "pnpm --recursive --if-present clean && rm -rf node_modules",
    "lint": "pnpm --recursive --if-present lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "security:check": "bash scripts/security-check.sh || echo 'Security check not configured'",
    "security:scan": "bash scripts/security-scan.sh || echo 'Security scan not configured'",
    "security:verify": "bash scripts/security-verify.sh || echo 'Security verify not configured'",
    "prepare": "husky install || echo 'Husky not installed, skipping git hooks'"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lerna": "^8.1.9",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "author": "",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ]
}
