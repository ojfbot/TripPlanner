{
  "comment": "Copy this file to env.json and fill in your API keys",

  "anthropicApiKey": "YOUR_ANTHROPIC_API_KEY_HERE",

  "directories": {
    "trips": "trips",
    "itineraries": "itineraries",
    "research": "research",
    "exports": "exports",
    "temp": "temp"
  },

  "model": "claude-sonnet-4-20250514",
  "temperature": 0.7,

  "database": {
    "type": "sqlite",
    "path": "./tripplanner.db"
  }
}
